<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="#E0F2FE" /> <corners android:radius="16dp" />
            <stroke android:width="2dp" android:color="#0080FF" /> </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#F8FAFC" /> <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#E2E8F0" />
        </shape>
    </item>
</selector>