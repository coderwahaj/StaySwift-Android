<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@android:color/white"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/ivProfileAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_profile_avatar"
            android:background="@drawable/circle_avatar_bg"
            android:padding="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textStyle="bold"
                android:textColor="#111827"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvProfilePhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+92 **********"
                android:textColor="#2563EB"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <TextView
            android:id="@+id/itemProfile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:drawablePadding="12dp"
            android:text="Profile"
            android:textColor="#111827"
            android:textSize="14sp"
            app:drawableStartCompat="@android:drawable/ic_menu_edit" />

        <TextView
            android:id="@+id/itemNotifications"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:drawablePadding="12dp"
            android:text="Notifications"
            android:textColor="#111827"
            android:textSize="14sp"
            app:drawableStartCompat="@android:drawable/ic_dialog_info" />

        <TextView
            android:id="@+id/itemSupport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:drawablePadding="12dp"
            android:text="Customer Support"
            android:textColor="#111827"
            android:textSize="14sp"
            app:drawableStartCompat="@android:drawable/ic_dialog_email" />

        <TextView
            android:id="@+id/itemLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:drawablePadding="12dp"
            android:text="Logout"
            android:textColor="#EF4444"
            android:textSize="14sp"
            app:drawableStartCompat="@android:drawable/ic_lock_power_off" />
    </LinearLayout>
</LinearLayout>