<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <View
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/bg_admin_header_mesh" />

    <LinearLayout
        android:id="@+id/headerTextContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="45dp">

        <TextView
            android:id="@+id/tvHeaderRoomEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="4sp"
            android:text="Edit Room Category"
            android:textSize="26sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.85"
            android:letterSpacing="0.02"
            android:text="Configure pricing, occupancy, and features"
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerTextContainer"
        android:layout_marginTop="-20dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="32dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Basic Information"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRoomCategory"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Room Category"
                    app:boxStrokeColor="#0080FF"
                    app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">

                    <AutoCompleteTextView
                        android:id="@+id/actRoomCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Description"
                    app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRoomDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:minLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Pricing &amp; Inventory"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Base Price"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBasePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Discount"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDiscountPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Total Rooms"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTotalRooms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Available"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAvailableRooms"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Occupancy &amp; Specs"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textAllCaps="true" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Max Adults"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaxAdults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Max Kids"
                        app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMaxChildren"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Bed Type"
                    app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBedType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Room Size (Sqft)"
                    app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRoomSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Amenities"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:textAllCaps="true" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins">

                    <CheckBox android:id="@+id/cbRoomAc" android:layout_width="0dp" android:layout_columnWeight="1" android:text="AC" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomWifi" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Wi-Fi" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomTv" android:layout_width="0dp" android:layout_columnWeight="1" android:text="TV" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomBreakfast" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Breakfast" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomHeater" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Heater" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomMiniBar" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Mini Bar" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomBath" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Private Bath" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomBalcony" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Balcony" android:buttonTint="#0080FF" />
                    <CheckBox android:id="@+id/cbRoomSmoking" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Smoking" android:buttonTint="#0080FF" />
                </GridLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Other amenities (optional)"
                    app:boxCornerRadiusTopStart="16dp" app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp" app:boxCornerRadiusBottomEnd="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRoomOtherAmenities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_amenity_selector"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:fontFamily="sans-serif-medium"
                        android:text="Active category status"
                        android:textColor="#1E293B" />

                    <Switch
                        android:id="@+id/swRoomActive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:checked="true"
                        android:thumbTint="#0080FF" />
                </RelativeLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveRoomCategory"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Save Room Settings"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:backgroundTint="#0080FF"
                        app:cornerRadius="20dp"
                        app:elevation="6dp" />

                    <ProgressBar
                        android:id="@+id/progressSaveRoom"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@android:color/white"
                        android:visibility="gone" />
                </FrameLayout>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>