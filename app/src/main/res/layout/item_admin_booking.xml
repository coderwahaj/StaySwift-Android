<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvAdminBookingHotel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hotel name"
            android:textStyle="bold"
            android:textColor="@color/textPrimary" />

        <TextView
            android:id="@+id/tvAdminBookingUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="User: uid"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAdminBookingDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Check-in / Check-out"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAdminBookingMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Room • Rooms • Nights"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvAdminBookingAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Rs 0 • Status"
            android:textStyle="bold"
            android:textColor="@color/primaryBlue" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>