<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <View
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_admin_header_mesh" />

    <LinearLayout
        android:id="@+id/headerTextContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Hotel Details"
            android:textColor="@android:color/white"
            android:textSize="32sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_alpha_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Management"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:alpha="0.9"
                android:text="View and modify property"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerTextContainer"
        android:layout_marginTop="-20dp"
        app:cardBackgroundColor="#F8FAFC"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp">

        <ScrollView
            android:id="@+id/rootScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="120dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <androidx.viewpager2.widget.ViewPager2
                            android:id="@+id/vpHotelImages"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <ProgressBar
                            android:id="@+id/progressHotelDetails"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerInParent="true"
                            android:indeterminateTint="@color/primaryBlue"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvImageIndex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true"
                            android:layout_marginBottom="20dp"
                            android:background="@drawable/bg_image_index"
                            android:elevation="4dp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:text="1/1"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvHotelName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:textColor="#1E293B"
                            android:textSize="26sp" />

                        <TextView
                            android:id="@+id/tvHotelAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:drawablePadding="8dp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#64748B"
                            app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                            app:drawableTint="@color/primaryBlue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_blue_light"
                                android:padding="7dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="@color/primaryBlue" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="sans-serif-bold"
                                android:text="About this Hotel"
                                android:textAllCaps="true"
                                android:textColor="@color/primaryBlue"
                                android:textSize="12sp"
                                android:letterSpacing="0.1" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvHotelDesc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="6dp"
                            android:textColor="#334155"
                            android:textSize="15sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:text="Contact &amp; Services"
                            android:textColor="@color/primaryBlue"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvHotelPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:textColor="#334155"
                            android:textSize="15sp"
                            android:drawablePadding="12dp"
                            app:drawableStartCompat="@android:drawable/ic_menu_call"
                            app:drawableTint="@color/primaryBlue"/>

                        <TextView
                            android:id="@+id/tvHotelEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="#334155"
                            android:textSize="15sp"
                            android:drawablePadding="12dp"
                            app:drawableStartCompat="@android:drawable/ic_dialog_email"
                            app:drawableTint="@color/primaryBlue"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="16dp"
                            android:background="#F1F5F9" />

                        <TextView
                            android:id="@+id/tvHotelAmenities"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#475569"
                            android:lineSpacingExtra="4dp"
                            android:drawablePadding="12dp"
                            app:drawableStartCompat="@android:drawable/btn_star_big_on"
                            app:drawableTint="#F59E0B"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1"
                            android:text="Property Location"
                            android:textColor="@color/primaryBlue"
                            android:textSize="12sp" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:layout_marginTop="16dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#F1F5F9"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/ivMapThumbnail"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:background="#F8FAFC"
                                android:src="@android:drawable/ic_menu_mapmode" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:elevation="24dp"
        android:orientation="horizontal"
        android:padding="20dp"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditHotelDetail"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1.2"
            android:fontFamily="sans-serif-black"
            android:text="Edit Details"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/primaryBlue"
            app:cornerRadius="24dp"
            app:elevation="8dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteHotelDetail"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="8dp"
            android:layout_weight="0.8"
            android:fontFamily="sans-serif-bold"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="#E11D48"
            app:backgroundTint="#FFF1F2"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconGravity="textStart"
            app:iconTint="#E11D48"
            app:rippleColor="#FEE2E2"
            app:strokeColor="#FECDD3"
            app:strokeWidth="1dp" />

    </LinearLayout>

</RelativeLayout>